    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.2",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.8.9",
    "serwist": "^9.5.7",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
