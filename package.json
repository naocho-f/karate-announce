    "idb-keyval": "^6.2.2",
    "next": "^16.2.2",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.9.4"
  },
  "browserslist": [
    "> 0.5%",
    "last 4 versions",
    "not dead",
    "Chrome >= 80",
    "Android >= 80"
  ],
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@serwist/turbopack": "^9.5.7",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
