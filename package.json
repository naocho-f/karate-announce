{
  "name": "karate-announce",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --include '__tests__/unit/**'",
    "test:api": "vitest run --include '__tests__/api/**'",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:all": "vitest run && playwright test",
    "security:lint": "eslint . --max-warnings 0 && tsc --noEmit",
    "security:scan": "sh scripts/security-scan.sh",
    "security:check": "npm run security:lint && npm run security:scan",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --max-warnings 0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "@tailwindcss/typography": "^0.5.19",
    "esbuild": "^0.27.7",
    "esbuild-wasm": "^0.28.0",
    "idb-keyval": "^6.2.2",
    "next": "^16.2.3",
    "qrcode": "^1.5.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.10.0"
  },
  "browserslist": [
    "> 0.5%",
    "last 4 versions",
    "not dead",
    "Chrome >= 80",
    "Android >= 80"
  ],
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@serwist/turbopack": "^9.5.7",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.4",
    "dotenv": "^17.4.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-security": "^4.0.0",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "serwist": "^9.5.7",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
