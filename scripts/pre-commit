#!/bin/sh
# SPEC.md がステージされていないコミットをブロック
if ! git diff --cached --name-only | grep -q '^SPEC.md$'; then
  echo ""
  echo "ERROR: SPEC.md がコミットに含まれていません。"
  echo "SPEC.md を更新してから git add SPEC.md してください。"
  echo ""
  exit 1
fi

# SPEC.md ヘッダーの「最終更新」日付が当日か確認
TODAY=$(date +%Y-%m-%d)
SPEC_DATE=$(grep '最終更新:' SPEC.md | head -1 | grep -oE '[0-9]{4}-[0-9]{2}-[0-9]{2}')
if [ -n "$SPEC_DATE" ] && [ "$SPEC_DATE" != "$TODAY" ]; then
  echo ""
  echo "ERROR: SPEC.md の最終更新日が古いです（${SPEC_DATE}）。"
  echo "ヘッダーの日付を ${TODAY} に更新してください。"
  echo ""
  exit 1
fi

# RPC 整合性チェック: コード内の rpc() 呼び出しに対応するマイグレーションがあるか
RPC_MISSING=""
for rpc_name in $(grep -roh 'supabase\.rpc("[^"]*"' app/ lib/ 2>/dev/null | sed 's/.*rpc("//;s/"//' | sort -u); do
  if ! grep -rql "FUNCTION.*${rpc_name}" supabase/migrations/ 2>/dev/null; then
    RPC_MISSING="${RPC_MISSING}  - ${rpc_name}\n"
  fi
done
if [ -n "$RPC_MISSING" ]; then
  echo ""
  echo "ERROR: 以下の RPC 関数にマイグレーションファイルがありません:"
  printf "$RPC_MISSING"
  echo "supabase/migrations/ に CREATE OR REPLACE FUNCTION を追加してください。"
  echo ""
  exit 1
fi

# 仕様書参照チェック: docs/ の全 *_SPEC.md が SPEC.md から参照されているか
SPEC_MISSING=""
for spec in docs/*_SPEC.md; do
  [ -f "$spec" ] || continue
  specname=$(basename "$spec")
  if ! grep -q "$specname" SPEC.md; then
    SPEC_MISSING="${SPEC_MISSING}  - ${specname}\n"
  fi
done
if [ -n "$SPEC_MISSING" ]; then
  echo ""
  echo "ERROR: 以下の仕様書が SPEC.md から参照されていません:"
  printf "$SPEC_MISSING"
  echo "SPEC.md にリンクを追加してください。"
  echo ""
  exit 1
fi

# APIルートのテスト存在チェック: app/api/ の全 route.ts に対応するテストがあるか
ROUTE_MISSING=""
for route in $(find app/api -name 'route.ts' 2>/dev/null); do
  # ルートのimportパス（@/app/api/...）を構築
  import_path=$(echo "$route" | sed 's|\.ts$||')
  # URLパス（/api/...）を構築してブラケット除去
  url_path=$(echo "$route" | sed 's|^app/api|/api|;s|/route\.ts$||;s/\[.*\]//g;s|/$||')
  # テストファイル内にimportパスまたはURLパスへの参照があるか（-F: 固定文字列、[id]等をエスケープ不要に）
  if ! grep -rFql "@/${import_path}" __tests__/ 2>/dev/null; then
    if ! grep -rFql "${url_path}" __tests__/ 2>/dev/null; then
      ROUTE_MISSING="${ROUTE_MISSING}  - ${route}\n"
    fi
  fi
done
if [ -n "$ROUTE_MISSING" ]; then
  echo ""
  echo "WARNING: 以下の API ルートにテストがありません:"
  printf "$ROUTE_MISSING"
  echo "__tests__/api/ にテストを追加してください。"
  echo ""
  # WARNING: テスト不足はブロックせず警告のみ（既存ルートに段階的に対応するため）
fi

# SPEC.md API一覧の完全性チェック: 全 route.ts のURLパスが SPEC.md に記載されているか
API_MISSING=""
for route in $(find app/api -name 'route.ts' 2>/dev/null); do
  # URLパスを構築（/api/admin/events/[id] → /api/admin/events/[id]）
  url_path=$(echo "$route" | sed 's|^app||;s|/route\.ts$||')
  if ! grep -Fq "$url_path" SPEC.md; then
    # [id] をワイルドカードに置換して再チェック（SPEC.md では [id] 表記のはず）
    url_no_bracket=$(echo "$url_path" | sed 's/\[.*\]//g;s|/$||')
    if ! grep -Fq "$url_no_bracket" SPEC.md; then
      API_MISSING="${API_MISSING}  - ${url_path}\n"
    fi
  fi
done
if [ -n "$API_MISSING" ]; then
  echo ""
  echo "ERROR: 以下の API ルートが SPEC.md に記載されていません:"
  printf "$API_MISSING"
  echo "SPEC.md Section 5 に追加してください。"
  echo ""
  exit 1
fi

# lib/ テストファイル存在チェック: lib/*.ts に対応する __tests__/unit/*.test.ts があるか
LIB_MISSING=""
for libfile in lib/*.ts lib/*.tsx; do
  [ -f "$libfile" ] || continue
  libname=$(basename "$libfile" .ts)
  libname=$(echo "$libname" | sed 's/\.tsx$//')
  # supabase クライアント初期化ファイルはテスト対象外
  case "$libname" in supabase|supabase-admin) continue;; esac
  if [ ! -f "__tests__/unit/${libname}.test.ts" ] && [ ! -f "__tests__/unit/${libname}.test.tsx" ]; then
    LIB_MISSING="${LIB_MISSING}  - ${libfile}\n"
  fi
done
if [ -n "$LIB_MISSING" ]; then
  echo ""
  echo "WARNING: 以下の lib/ ファイルにテストがありません:"
  printf "$LIB_MISSING"
  echo "__tests__/unit/ にテストを追加してください。"
  echo ""
fi

# 逆方向チェック: SPEC.md のAPI一覧に載っているパスが実際に route.ts として存在するか
SPEC_API_STALE=""
grep -oE '`/api/[^`]+`' SPEC.md | sed 's/`//g;s/\?.*//;s/#.*//' | sort -u | while read api_path; do
  # /api/admin/events/[id] → app/api/admin/events/[id]/route.ts
  route_file="app${api_path}/route.ts"
  if [ ! -f "$route_file" ]; then
    echo "$api_path" >> /tmp/pre-commit-stale-apis
  fi
done
if [ -f /tmp/pre-commit-stale-apis ]; then
  SPEC_API_STALE=$(cat /tmp/pre-commit-stale-apis)
  rm -f /tmp/pre-commit-stale-apis
  if [ -n "$SPEC_API_STALE" ]; then
    echo ""
    echo "ERROR: SPEC.md に記載されているが存在しない API ルートがあります:"
    echo "$SPEC_API_STALE" | while read line; do echo "  - $line"; done
    echo "SPEC.md から削除��るか、ルートを作成してください。"
    echo ""
    exit 1
  fi
fi
rm -f /tmp/pre-commit-stale-apis

# ページ→SPEC.md チェック: app/ の page.tsx が SPEC.md 画面一覧に記載されているか
PAGE_MISSING=""
for pagefile in $(find app -name 'page.tsx' -not -path '*/api/*' 2>/dev/null); do
  # app/court/[court]/page.tsx → /court/[court]
  page_path=$(echo "$pagefile" | sed 's|^app||;s|/page\.tsx$||')
  [ -z "$page_path" ] && page_path="/"
  if ! grep -Fq "$page_path" SPEC.md; then
    # ブラケット除去して再チェック
    page_clean=$(echo "$page_path" | sed 's/\[.*\]//g;s|/$||')
    if ! grep -Fq "$page_clean" SPEC.md; then
      PAGE_MISSING="${PAGE_MISSING}  - ${page_path} (${pagefile})\n"
    fi
  fi
done
if [ -n "$PAGE_MISSING" ]; then
  echo ""
  echo "ERROR: 以下のページが SPEC.md 画面一覧に記載されていません:"
  printf "$PAGE_MISSING"
  echo "SPEC.md Section 3 に追加してください。"
  echo ""
  exit 1
fi

# hook 同期チェック: scripts/pre-commit と .git/hooks/pre-commit が一致するか
if [ -f "scripts/pre-commit" ]; then
  if ! diff -q scripts/pre-commit .git/hooks/pre-commit > /dev/null 2>&1; then
    echo ""
    echo "ERROR: scripts/pre-commit と .git/hooks/pre-commit が一致しません。"
    echo "cp scripts/pre-commit .git/hooks/pre-commit で同期してください。"
    echo ""
    exit 1
  fi
fi

# TypeScript 型チェック
echo "Running tsc --noEmit..."
npx tsc --noEmit
if [ $? -ne 0 ]; then
  echo ""
  echo "ERROR: TypeScript 型チェックに失敗しました。"
  echo ""
  exit 1
fi

# テスト実行
echo "Running vitest..."
npx vitest run
if [ $? -ne 0 ]; then
  echo ""
  echo "ERROR: テストが失敗しました。"
  echo ""
  exit 1
fi

# ビルド
echo "Running build..."
npm run build
if [ $? -ne 0 ]; then
  echo ""
  echo "ERROR: ビルドに失敗しました。"
  echo ""
  exit 1
fi
