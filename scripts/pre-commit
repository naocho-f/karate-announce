#!/bin/sh
# ============================================================
# pre-commit hook — 品質チェック
#
# ソース: scripts/pre-commit（Git管理）
# 自動インストール: npm install 時に prepare スクリプトが実行
#
# 構成:
#   Phase 1: 静的チェック（grep系、即座に完了）→ ERRORでブロック
#   Phase 2: 警告チェック（grep系）→ 新規分のみ表示
#   Phase 3: 動的チェック（tsc→vitest）→ ERRORでブロック（buildはCI/Vercelが担当）
# ============================================================

set -e

# ── Phase 1: 静的チェック（ブロック） ─────────────────────────

# 1. SPEC.md がコミットに含まれるか
if ! git diff --cached --name-only | grep -q '^SPEC.md$'; then
  echo ""; echo "ERROR: SPEC.md がコミットに含まれていません。"; echo ""
  exit 1
fi

# 2. SPEC.md 日付が当日か
TODAY=$(date +%Y-%m-%d)
SPEC_DATE=$(grep '最終更新:' SPEC.md | head -1 | grep -oE '[0-9]{4}-[0-9]{2}-[0-9]{2}')
if [ -n "$SPEC_DATE" ] && [ "$SPEC_DATE" != "$TODAY" ]; then
  echo ""; echo "ERROR: SPEC.md の最終更新日が古いです（${SPEC_DATE} → ${TODAY}）"; echo ""
  exit 1
fi

# 3. rpc() → マイグレーション存在
for rpc_name in $(grep -roh 'supabase\.rpc("[^"]*"' app/ lib/ 2>/dev/null | sed 's/.*rpc("//;s/"//' | sort -u); do
  if ! grep -rql "FUNCTION.*${rpc_name}" supabase/migrations/ 2>/dev/null; then
    echo ""; echo "ERROR: RPC '${rpc_name}' のマイグレーションがありません"; echo ""
    exit 1
  fi
done

# 4. docs/*_SPEC.md → SPEC.md 参照あり
for spec in docs/*_SPEC.md; do
  [ -f "$spec" ] || continue
  if ! grep -q "$(basename "$spec")" SPEC.md; then
    echo ""; echo "ERROR: $(basename "$spec") が SPEC.md から参照されていません"; echo ""
    exit 1
  fi
done

# 5. SPEC.md 仕様書リンク → docs/ファイル存在
for docpath in $(grep -oE '\(docs/[^)]+\)' SPEC.md | sed 's/[()]//g' | sort -u); do
  if [ ! -f "$docpath" ]; then
    echo ""; echo "ERROR: SPEC.md のリンク先 ${docpath} が存在しません"; echo ""
    exit 1
  fi
done

# 6. route.ts → SPEC.md API一覧に記載
for route in $(find app/api -name 'route.ts' 2>/dev/null); do
  url_path=$(echo "$route" | sed 's|^app||;s|/route\.ts$||')
  if ! grep -Fq "$url_path" SPEC.md; then
    url_no_bracket=$(echo "$url_path" | sed 's/\[.*\]//g;s|/$||')
    if ! grep -Fq "$url_no_bracket" SPEC.md; then
      echo ""; echo "ERROR: API ${url_path} が SPEC.md に記載されていません"; echo ""
      exit 1
    fi
  fi
done

# 7. SPEC.md API一覧 → route.ts 存在（逆方向）
for api_path in $(grep -oE '`/api/[^`]+`' SPEC.md | sed 's/`//g;s/\?.*//;s/#.*//' | sort -u); do
  if [ ! -f "app${api_path}/route.ts" ]; then
    echo ""; echo "ERROR: SPEC.md に記載の API ${api_path} が存在しません"; echo ""
    exit 1
  fi
done

# 8. page.tsx → SPEC.md 画面一覧に記載
for pagefile in $(find app -name 'page.tsx' -not -path '*/api/*' 2>/dev/null); do
  page_path=$(echo "$pagefile" | sed 's|^app||;s|/page\.tsx$||')
  [ -z "$page_path" ] && page_path="/"
  if ! grep -Fq "$page_path" SPEC.md; then
    page_clean=$(echo "$page_path" | sed 's/\[.*\]//g;s|/$||')
    if ! grep -Fq "$page_clean" SPEC.md; then
      echo ""; echo "ERROR: ページ ${page_path} が SPEC.md に記載されていません"; echo ""
      exit 1
    fi
  fi
done

# 9. admin/court API → verifyAdminAuth 呼出
for route in $(find app/api/admin app/api/court -name 'route.ts' 2>/dev/null); do
  case "$route" in */login/*) continue;; esac
  if ! grep -q 'verifyAdminAuth' "$route"; then
    echo ""; echo "ERROR: ${route} で verifyAdminAuth が呼ばれていません"; echo ""
    exit 1
  fi
done

# 10. eslint-disable コメント禁止（例外なし）
if grep -rn 'eslint-disable' app/ lib/ components/ __tests__/ 2>/dev/null | grep -v 'node_modules'; then
  echo ""; echo "ERROR: eslint-disable コメントが見つかりました。使用は禁止です。根本原因を修正してください。"; echo ""
  exit 1
fi

# 11. lib/ の export がアプリコードから使われているか（テストのみは不可）
# 新規追加・変更された lib/ ファイルの export を検証
for libfile in $(git diff --cached --name-only --diff-filter=AM | grep '^lib/[^/]*\.ts$'); do
  libname=$(basename "$libfile" .ts | sed 's/\.tsx$//')
  # types.ts, supabase*.ts, errors.ts は除外（型定義・設定・基盤）
  case "$libname" in types|supabase|supabase-admin|errors) continue;; esac
  for funcname in $(grep -oE 'export (function|const|class|type|interface) [a-zA-Z_]+' "$libfile" 2>/dev/null | awk '{print $NF}'); do
    # type/interface は除外
    if grep -qE "export (type|interface) ${funcname}" "$libfile" 2>/dev/null; then continue; fi
    # app/ components/ lib/ から参照されているか（自分自身とテスト除外）
    app_refs=$(grep -rl "$funcname" app/ components/ lib/ 2>/dev/null | grep -v "$libfile" | grep -v '__tests__/' | head -1)
    if [ -z "$app_refs" ]; then
      echo ""; echo "ERROR: ${libfile} の export '${funcname}' がアプリコードから使われていません（テストのみ不可）"; echo ""
      exit 1
    fi
  done
done

echo "Static checks passed."

# ── Phase 2: 警告（新規分のみ表示） ──────────────────────────

WARN_FILE="/tmp/pre-commit-warnings-$$"
BASELINE=".warnings-baseline"

# テスト存在チェック（API routes）
for route in $(find app/api -name 'route.ts' 2>/dev/null); do
  import_path=$(echo "$route" | sed 's|\.ts$||')
  url_path=$(echo "$route" | sed 's|^app/api|/api|;s|/route\.ts$||;s/\[.*\]//g;s|/$||')
  if ! grep -rFql "@/${import_path}" __tests__/ 2>/dev/null; then
    if ! grep -rFql "${url_path}" __tests__/ 2>/dev/null; then
      echo "API_NO_TEST: ${route}" >> "$WARN_FILE"
    fi
  fi
done

# テスト存在チェック（lib/）
for libfile in lib/*.ts lib/*.tsx; do
  [ -f "$libfile" ] || continue
  libname=$(basename "$libfile" .ts)
  libname=$(echo "$libname" | sed 's/\.tsx$//')
  case "$libname" in supabase|supabase-admin) continue;; esac
  if [ ! -f "__tests__/unit/${libname}.test.ts" ] && [ ! -f "__tests__/unit/${libname}.test.tsx" ]; then
    echo "LIB_NO_TEST: ${libfile}" >> "$WARN_FILE"
  fi
done

# テスト存在チェック（components/）— ユニットテストまたはE2Eテストで検証されていること
for compfile in components/*.tsx; do
  [ -f "$compfile" ] || continue
  compname=$(basename "$compfile" .tsx)
  compname_stripped="${compname#_}"
  has_test=false
  [ -f "__tests__/unit/${compname}.test.ts" ] || [ -f "__tests__/unit/${compname}.test.tsx" ] && has_test=true
  [ -f "__tests__/unit/${compname_stripped}.test.ts" ] || [ -f "__tests__/unit/${compname_stripped}.test.tsx" ] && has_test=true
  if [ "$has_test" = false ] && grep -rql "$compname" __tests__/e2e/ 2>/dev/null; then has_test=true; fi
  if [ "$has_test" = false ]; then
    echo "COMP_NO_TEST: ${compfile}" >> "$WARN_FILE"
  fi
done

# 環境変数チェック
for envvar in $(grep -roh 'process\.env\.\w\+' app/ lib/ 2>/dev/null | sed 's/process\.env\.//' | sort -u); do
  case "$envvar" in NODE_ENV|__NEXT*|TZ) continue;; esac
  if ! grep -Fq "$envvar" CLAUDE.md; then
    echo "ENV_UNDOC: ${envvar}" >> "$WARN_FILE"
  fi
done

# SPEC.md 画面一覧→page.tsx 逆方向
for page_path in $(grep -oE '\| `/[^`]+`' SPEC.md | sed 's/| `//;s/`//' | grep -v '^/api/' | sort -u); do
  if [ ! -f "app${page_path}/page.tsx" ]; then
    echo "PAGE_STALE: ${page_path}" >> "$WARN_FILE"
  fi
done

# ベースラインと比較して新規警告のみ表示
if [ -f "$WARN_FILE" ]; then
  if [ -f "$BASELINE" ]; then
    NEW_WARNINGS=$(diff "$BASELINE" "$WARN_FILE" 2>/dev/null | grep '^>' | sed 's/^> //' || true)
  else
    NEW_WARNINGS=$(cat "$WARN_FILE")
  fi
  if [ -n "$NEW_WARNINGS" ]; then
    echo ""
    echo "=== 新しい警告 ==="
    echo "$NEW_WARNINGS"
    echo "==================="
    echo "（これらの警告は解消するまで毎回表示されます）"
    echo ""
  fi
  rm -f "$WARN_FILE"
else
  rm -f "$WARN_FILE"
fi

# ── Phase 3: 動的チェック（ブロック） ─────────────────────────
# build は CI と Vercel が担当するため pre-commit では実行しない（高速化）

# ツール存在チェック
for cmd in gitleaks semgrep; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "ERROR: ${cmd} がインストールされていません。brew install ${cmd} を実行してください。"
    exit 1
  fi
done

echo "Running eslint (staged files)..."
npx lint-staged || { echo ""; echo "ERROR: ESLint エラーまたは警告があります"; exit 1; }

echo "Running tsc --noEmit..."
npx tsc --noEmit || { echo ""; echo "ERROR: TypeScript 型チェック失敗"; exit 1; }

echo "Running vitest..."
npx vitest run || { echo ""; echo "ERROR: テスト失敗"; exit 1; }

echo "Running gitleaks..."
gitleaks protect --staged --config .gitleaks.toml || { echo ""; echo "ERROR: シークレットが検出されました"; exit 1; }

echo "Running semgrep..."
SEMGREP_ARGS="--config p/typescript --config p/react --config p/nextjs --config p/owasp-top-ten --config p/javascript --config p/secrets"
STAGED_TS=$(git diff --cached --name-only --diff-filter=ACM -- '*.ts' '*.tsx')
if [ -n "$STAGED_TS" ]; then
  echo "$STAGED_TS" | xargs semgrep $SEMGREP_ARGS --error --quiet || { echo ""; echo "ERROR: Semgrep セキュリティ問題が検出されました"; exit 1; }
fi
